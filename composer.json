{
  "name": "senih25/dijital-sosyal-hak-platformu",
  "description": "AI-supported digital platform for analyzing social rights, legal eligibility and public benefit access.",
  "type": "project",
  "license": "MIT",

  "require": {
    "php": "^8.1",
    "vlucas/phpdotenv": "^5.5",
    "monolog/monolog": "^3.0"
  },

  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },

  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },

  "scripts": {
    "test": "phpunit",
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-update-cmd": [
      "@php -r \"echo 'Dependencies updated successfully.';\""
    ]
  },

  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },

  "minimum-stability": "stable",
  "prefer-stable": true
}